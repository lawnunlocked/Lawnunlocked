    .nav-cta{display:inline-flex;align-items:center;background:var(--green);color:white;padding:0.5rem 1.1rem;border-radius:7px;text-decoration:none;font-weight:600;font-size:0.82rem;white-space:nowrap;transition:background 0.2s}
