    .btn-newsletter{display:block;width:100%;text-align:center;background:var(--ink);color:white;padding:0.7rem;border-radius:7px;font-weight:600;font-size:0.83rem;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background 0.2s}
    .btn-newsletter:hover{background:#333}
    .sw-fine{font-size:0.66rem;color:var(--mid);text-align:center;margin-top:0.45rem}
    .sw-pick{display:flex;gap:0.7rem;align-items:flex-start;padding:0.8rem 0;border-bottom:1px solid var(--border)}
