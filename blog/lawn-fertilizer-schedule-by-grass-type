    .compare-table td{padding:0.65rem 0.9rem;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.5}
    .compare-table tr:last-child td{border-bottom:none}
    .compare-table tr:nth-child(even) td{background:var(--gray)}
    .compare-table td:first-child{font-weight:600;color:var(--ink)}

    /* PRODUCT CALLOUT */
    .product-callout{background:var(--ink);border-radius:12px;padding:1.25rem 1.4rem;margin:1.75rem 0;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
