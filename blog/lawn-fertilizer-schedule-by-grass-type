    .product-callout-name{font-size:0.95rem;font-weight:600;color:white;margin-bottom:0.18rem}
    .product-callout-why{font-size:0.78rem;color:#aaa;line-height:1.5;max-width:400px}

    /* MID CTA */
    .mid-quiz-cta{background:linear-gradient(135deg,#1a3d1f,#2d5a27);border-radius:13px;padding:1.75rem;margin:2.5rem 0;text-align:center}
    .mid-quiz-cta h3{font-family:'Playfair Display',serif;font-size:1.25rem;font-weight:700;color:white;margin-bottom:0.45rem}
    .mid-quiz-cta p{font-size:0.85rem;color:rgba(255,255,255,0.65);margin-bottom:1.1rem;line-height:1.6}
    .btn-quiz-mid{display:inline-flex;align-items:center;gap:0.4rem;background:var(--green-light);color:white;padding:0.78rem 1.5rem;border-radius:9px;font-weight:700;font-size:0.9rem;text-decoration:none;transition:background 0.2s}
    .btn-quiz-mid:hover{background:#5cb858}

    /* FAQ */
    .faq-section{margin-top:2.5rem}
    .faq-item{border-bottom:1px solid var(--border);padding:1.1rem 0}
    .faq-item:last-child{border-bottom:none}
    .faq-q{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--ink);margin-bottom:0.45rem}
    .faq-a{font-size:0.88rem;color:#444;line-height:1.7}
    .faq-a a{color:var(--green)}

    /* SIDEBAR */
    .sidebar-widget{background:var(--white);border:1px solid var(--border);border-radius:13px;overflow:hidden;margin-bottom:1.25rem}
    .sw-header{padding:0.85rem 1.1rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:0.55rem}
    .sw-label{font-size:0.65rem;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:var(--green)}
    .sw-body{padding:1.1rem}
    .sw-title{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;color:var(--ink);line-height:1.3;margin-bottom:0.45rem}
    .sw-desc{font-size:0.78rem;color:#555;line-height:1.6;margin-bottom:0.85rem}
    .sw-checklist{display:flex;flex-direction:column;gap:0.28rem;margin-bottom:0.85rem}
    .sw-check{font-size:0.75rem;color:#444;display:flex;align-items:flex-start;gap:0.4rem;line-height:1.4}
    .sw-check::before{content:'\2713';color:var(--green-light);font-weight:700;flex-shrink:0}
    .btn-quiz-cta{display:block;text-align:center;background:var(--green);color:white;padding:0.75rem 1.1rem;border-radius:8px;font-weight:600;font-size:0.85rem;text-decoration:none;transition:background 0.2s}
    .btn-quiz-cta:hover{background:var(--green-light)}
    .sw-newsletter-input{width:100%;padding:0.65rem 0.85rem;border:1.5px solid var(--border);border-radius:7px;font-family:'DM Sans',sans-serif;font-size:0.83rem;outline:none;background:var(--gray);margin-bottom:0.45rem;transition:border-color 0.2s}
