    .drawer{position:fixed;top:0;left:0;bottom:0;z-index:500;width:280px;background:var(--white);transform:translateX(-100%);transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);overflow-y:auto;display:flex;flex-direction:column}
